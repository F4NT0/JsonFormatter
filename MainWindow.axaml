<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:JsonFormatter.ViewModels"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="JsonFormatter.MainWindow"
        Title="JSON Formatter - Fanto Edition"
        Icon="avares://JsonFormatter/Assets/Icons/logo.png"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="700"
        Background="#1A1D2E">

    <Window.Styles>
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="#2A2D3E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#44475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#383B4D"/>
        </Style>
        <Style Selector="Button.copy-btn">
            <Setter Property="Background" Value="#2A2D3E"/>
            <Setter Property="Foreground" Value="#8BE9FD"/>
            <Setter Property="BorderBrush" Value="#8BE9FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.copy-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E3A45"/>
        </Style>
        <Style Selector="Button.beautify-btn">
            <Setter Property="Background" Value="#2D4A3E"/>
            <Setter Property="Foreground" Value="#50FA7B"/>
            <Setter Property="BorderBrush" Value="#50FA7B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.beautify-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E3A2D"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- TOP TITLE BAR -->
        <Border Grid.Row="0" Background="#13152A" Padding="20,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{}{ }" FontSize="20" FontWeight="Bold" Foreground="#8BE9FD" VerticalAlignment="Center"/>
                <TextBlock Text="JSON Formatter" FontSize="18" FontWeight="SemiBold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
                <TextBlock Text="— Fanto Edition" FontSize="13" Foreground="#6272A4" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" ColumnDefinitions="*,300" Margin="16,12,16,8">

            <!-- LEFT: Editor Panel -->
            <Border Grid.Column="0"
                    Background="#13152A"
                    BorderBrush="#44475A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,12,0"
                    ClipToBounds="True">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#1E2030" CornerRadius="8,8,0,0" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="JSON Editor" Foreground="#6272A4" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Watermark="Search in JSON..."
                                     Background="#13152A"
                                     Foreground="#CDD6F4"
                                     BorderBrush="#44475A"
                                     BorderThickness="1"
                                     CornerRadius="4"
                                     FontSize="12"
                                     Padding="8,4"
                                     VerticalAlignment="Center"
                                     FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Cascadia Code,Consolas,monospace"
                                     CaretBrush="#CDD6F4"/>
                            <TextBlock x:Name="SearchStatusIcon"
                                       Grid.Column="2"
                                       FontSize="18" Width="26" Height="26"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Padding="2" VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       IsVisible="False"
                                       FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Segoe UI,sans-serif"/>
                        </Grid>
                    </Border>

                    <!-- Editor: TextBox for input, TextBlock for highlighted output -->
                    <Grid Grid.Row="1">
                        <!-- TextBox for editing (shown when not beautified) -->
                        <TextBox x:Name="Editor"
                                 Background="#13152A"
                                 Foreground="#CDD6F4"
                                 FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Cascadia Code,Consolas,Courier New,monospace"
                                 FontSize="14"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 BorderThickness="0"
                                 Padding="10,8"
                                 CaretBrush="#CDD6F4"
                                 SelectionBrush="#44475A"/>
                        
                        <!-- TextBlock for highlighted display (shown when beautified) -->
                        <ScrollViewer x:Name="HighlightedViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="#13152A"
                                      IsVisible="False">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock x:Name="LineNumbersText"
                                           Grid.Column="0"
                                           Foreground="#4E5568"
                                           FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Cascadia Code,Consolas,monospace"
                                           FontSize="14"
                                           TextWrapping="NoWrap"
                                           TextAlignment="Right"
                                           Padding="10,8,10,8"
                                           Background="#13152A"/>
                                <TextBlock x:Name="HighlightedText"
                                           Grid.Column="1"
                                           Foreground="#CDD6F4"
                                           FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Cascadia Code,Consolas,monospace"
                                           FontSize="14"
                                           TextWrapping="NoWrap"
                                           Padding="0,8,10,8"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- Error bar -->
                    <Border Grid.Row="2"
                            x:Name="ErrorBar"
                            IsVisible="False"
                            Background="#2D1B1B"
                            BorderBrush="#FF5555"
                            BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚠" Foreground="#FF5555" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ErrorText"
                                       Foreground="#FF8080"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- RIGHT: Controls Panel -->
            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">

                <!-- Status -->
                <Border Grid.Row="0"
                        Background="#1E2030"
                        BorderBrush="#44475A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,12">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="ValidDotText" Text="✗" VerticalAlignment="Center"
                                       FontSize="18" Width="26" Height="26"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Padding="2" Foreground="#FF5555"
                                       FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Segoe UI,sans-serif"/>
                            <TextBlock x:Name="ValidLabel" Text="JSON COMPLIANT" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#6272A4" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="FormattedDotText" Text="✗" VerticalAlignment="Center"
                                       FontSize="18" Width="26" Height="26"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Padding="2" Foreground="#FF5555"
                                       FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Segoe UI,sans-serif"/>
                            <TextBlock x:Name="FormattedLabel" Text="JSON FORMATTED" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#6272A4" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- One-line preview -->
                <Border Grid.Row="1"
                        Background="#13152A"
                        BorderBrush="#44475A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="0"
                        Margin="0,0,0,12">
                    <Grid RowDefinitions="Auto,Auto,Auto">
                        <Border Grid.Row="0" Background="#1E2030" CornerRadius="8,8,0,0" Padding="12,7">
                            <TextBlock Text="One-Line Version" Foreground="#6272A4" FontSize="11"/>
                        </Border>
                        <Border Grid.Row="1" MaxHeight="90" Padding="10,8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="OneLineText"
                                           Foreground="#8BE9FD"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           FontSize="11"
                                           TextWrapping="NoWrap"/>
                            </ScrollViewer>
                        </Border>
                        <Border Grid.Row="2" Padding="8,6" BorderBrush="#44475A" BorderThickness="0,1,0,0">
                            <Button Classes="copy-btn"
                                    Content="⎘  Copy One-Line"
                                    HorizontalAlignment="Stretch"
                                    Click="CopyOneLineBtn_Click"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Notification -->
                <Border Grid.Row="2"
                        x:Name="NotificationBorder"
                        IsVisible="False"
                        Background="#1E3A2D"
                        BorderBrush="#50FA7B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="NotifIcon" FontSize="18" Width="26" Height="26"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Padding="2" VerticalAlignment="Center"
                                   FontFamily="avares://JsonFormatter/Assets/Fonts#JetBrainsMono Nerd Font,Segoe UI,sans-serif"/>
                        <TextBlock x:Name="NotifText" Foreground="#CDD6F4" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>

        <!-- BOTTOM TOOLBAR -->
        <Border Grid.Row="2" Background="#13152A" BorderBrush="#44475A" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Paste or Import JSON → Beautify → Copy"
                           Foreground="#6272A4" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="EditBtn" Classes="action-btn" Content="✎ Edit" Click="EditBtn_Click" IsVisible="False"/>
                    <Button Classes="beautify-btn" Content="✦ Beautify" Click="BeautifyBtn_Click"/>
                    <Button Classes="action-btn"   Content="⎘ Copy"    Click="CopyBtn_Click"/>
                    <Button Classes="action-btn"   Content="✕ Clear"   Click="ClearBtn_Click"/>
                    <Button Classes="action-btn"   Content="↓ Import"  Click="ImportBtn_Click"/>
                    <Button Classes="action-btn"   Content="↑ Export"  Click="ExportBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
